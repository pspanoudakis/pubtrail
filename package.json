{
  "main": "expo-router/entry",
  "version": "1.0.0",
  "name": "pubtrail",
  "scripts": {
    "native:clean": "npx expo prebuild --clean",
    "android:dev": "npx expo run:android",
    "android:build_apk": "eas build --local --platform android --profile preview --output dist/pubtrail.apk",
    "web:publish": "npx expo export --platform web --output-dir web && firebase deploy --only hosting",
    "dev": "expo start",
    "dev_clear": "expo start --clear"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "3.0.2",
