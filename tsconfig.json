{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@reduxjs/toolkit": [
        "node_modules/@reduxjs/toolkit/dist/index.d.ts"
      ],
      "/*": [
        "*"
      ],
      "@/*": [
        "src/*"
      ]
    },
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "moduleSuffixes": [".native",".web", ""],
    "noEmit": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
